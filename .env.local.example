# Vercel / local — copy to .env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (Vercel env, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Pusat zona antar 3 km — WIRA Kuliner, Jl. Me. Wira 12 Parung Bogor
NEXT_PUBLIC_JALAN_WIRA_LAT=-6.427760
NEXT_PUBLIC_JALAN_WIRA_LNG=106.727392

# Uji coba: bypass Midtrans (true = tanpa popup bayar)
NEXT_PUBLIC_PAYMENT_BYPASS=true

# Beranda: panel admin/driver disembunyikan secara default
# Set true untuk tampilkan lagi di homepage
# NEXT_PUBLIC_SHOW_HOME_ADMIN=true
# NEXT_PUBLIC_SHOW_HOME_DRIVER=true

# Midtrans QRIS (go-live: set NEXT_PUBLIC_PAYMENT_BYPASS=false)
MIDTRANS_MERCHANT_ID=
MIDTRANS_SERVER_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_QRIS_ACQUIRER=gopay
# Webhook URL di dashboard Midtrans:
# https://wirakuliner.web.id/api/payment/webhook
# Komisi platform NGOJEK (default 10%)
PLATFORM_COMMISSION_RATE=0.10

# Edge Function secrets (set via supabase secrets)
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=
