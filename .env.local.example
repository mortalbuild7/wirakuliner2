# Vercel / local — copy to .env.local
# Domain production (jangan localhost) — https://wirakuliner.web.id
NEXT_PUBLIC_APP_URL=https://wirakuliner.web.id
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (Vercel env, never expose to client — JANGAN pakai prefix NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Upstash Redis — rate limit terdistribusi (login admin, pemesanan, pencarian driver)
# Buat database gratis di https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Postgres pooler Supavisor (transaction mode, port 6543) — untuk Prisma/raw SQL/serverless burst
# Dashboard Supabase → Settings → Database → Connection string → Transaction pooler
# SUPABASE_DB_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DATABASE_URL= (alias; otomatis dialihkan ke :6543 jika SUPABASE_USE_POOLER tidak false)
# SUPABASE_USE_POOLER=true

# Pusat zona antar 3 km — WIRA Kuliner, Jl. Me. Wira 12 Parung Bogor
NEXT_PUBLIC_JALAN_WIRA_LAT=-6.427760
NEXT_PUBLIC_JALAN_WIRA_LNG=106.727392

# Uji coba: bypass Midtrans (true = tanpa popup bayar)
NEXT_PUBLIC_PAYMENT_BYPASS=true

# Beranda: panel admin/driver disembunyikan secara default
# Set true untuk tampilkan lagi di homepage
# NEXT_PUBLIC_SHOW_HOME_ADMIN=true
# NEXT_PUBLIC_SHOW_HOME_DRIVER=true

# Midtrans QRIS (go-live: set NEXT_PUBLIC_PAYMENT_BYPASS=false)
MIDTRANS_MERCHANT_ID=
MIDTRANS_SERVER_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# false = Sandbox (uji coba) | true = Production (go-live)
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_QRIS_ACQUIRER=gopay
# Webhook URL di dashboard Midtrans:
# https://wirakuliner.web.id/api/payment/webhook
# Bagi hasil driver: 90% driver / 10% aplikasi (ongkir & NGOJEK)
PLATFORM_COMMISSION_RATE=0.10
# Markup produk merchant untuk aplikasi: Rp 1.000/unit (lihat src/lib/revenue-split.ts)
# true = langsung halaman Midtrans Snap (jika QRIS Core API belum aktif)
MIDTRANS_PREFER_SNAP=true

# Geocoding server-only (opsional — fallback Nominatim OSM jika kosong)
GOOGLE_GEOCODING_API_KEY=

# Zoho SMTP — email aktivasi admin (port 465 SSL/TLS, server-only)
# Gunakan SMTP_* (utama) atau ZOHO_SMTP_* (legacy) — jangan commit password ke git
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=admin@wirakuliner.web.id
SMTP_PASSWORD=
# Legacy alias (opsional jika SMTP_* sudah diisi):
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_USER=admin@wirakuliner.web.id
# ZOHO_SMTP_PASS=

# Edge Function secrets (set via supabase secrets)
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=
