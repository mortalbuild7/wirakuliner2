{
  "name": "wira-driver-app",
  "version": "1.0.0",
  "private": true,
  "description": "WIRA Driver — Capacitor Android shell",
  "scripts": {
    "sync": "npx cap sync android",
    "open": "npx cap open android",
    "copy:firebase": "node copy-google-services.mjs",
    "build:debug": "npm run copy:firebase && npm run sync && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/geolocation": "^7.1.2",
    "@capacitor/push-notifications": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  }
}
