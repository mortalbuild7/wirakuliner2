{
  "expo": {
    "name": "WIRA Driver",
    "slug": "wira-driver",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "wiradriver",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "id.web.wirakuliner.driver"
    },
    "android": {
      "package": "id.web.wirakuliner.driver",
      "softwareKeyboardLayoutMode": "resize",
      "backgroundColor": "#ffffff",
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "navigationBar": {
        "backgroundColor": "#ffffff",
        "barStyle": "dark-content"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10b981",
          "defaultChannel": "wira-driver-incoming-orders"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8fafc",
          "image": "./assets/splash-icon.png",
          "imageWidth": 280
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "WIRA Driver membutuhkan lokasi untuk pelacakan pengantaran."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-navigation-bar"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c44445c7-958c-4501-8440-85bf5ea325de",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "c44445c7-958c-4501-8440-85bf5ea325de"
      }
    },
    "owner": "daffacell"
  }
}
